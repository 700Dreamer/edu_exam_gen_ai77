# ── EduQuest AI Engine — Backend (FastAPI + Python) ──────────────────────────
FROM python:3.11-slim

# System deps needed by chromadb / flashrank
RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential \
        libgomp1 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install Python dependencies first (layer-caching optimisation)
COPY requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt

# Copy application source (excluding heavy data dirs — see .dockerignore)
COPY app.py server.py build_vector_db.py extract_data.py ./
COPY core/ ./core/
COPY ui/  ./ui/

# Runtime data directories — populated via Docker volumes so data is persisted
# across container rebuilds
RUN mkdir -p chroma_db

EXPOSE 8000

CMD ["uvicorn", "server:app", "--host", "0.0.0.0", "--port", "8000"]
